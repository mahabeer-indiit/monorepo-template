{
  "name": "@template/types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared end-to-end types — owned by backend, consumed by FE + mobile",
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@template/config-eslint": "workspace:*",
    "@template/config-ts": "workspace:*",
    "eslint": "^9.0.0",
    "typescript": "^5.6.2"
  }
}
